        <mxCell id="failback" value="Failback to AWS&lt;br&gt;GCP Write Fence&lt;br&gt;RDS 재초기화 + 역복제&lt;br&gt;lag 0 → AWS 복귀" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=9;" vertex="1" parent="1"><mxGeometry x="1375" y="627" width="160" height="82" as="geometry"/></mxCell>
        <mxCell id="mapping" value="AWS ↔ GCP 대응&lt;br&gt;&lt;b&gt;ALB ↔ Gateway&lt;br&gt;EKS ↔ GKE&lt;br&gt;ECR ↔ Artifact Registry&lt;br&gt;RDS ↔ Cloud SQL&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#8B5CF6;fontSize=9;" vertex="1" parent="1"><mxGeometry x="1375" y="724" width="160" height="82" as="geometry"/></mxCell>

        <mxCell id="principle" value="DR 핵심 원칙 — 어느 시점에도 Write 원본은 한 곳만 유지: AWS 쓰기 차단 확인 → Cloud SQL Promote → GCP egress 해제 → Route 53 GCP 전환" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF1F2;strokeColor=#DC2626;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="20" y="880" width="1560" height="40" as="geometry"/></mxCell>

